<ui:Page x:Class="ExamSettings.Pages.ExamEditer"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
         xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
         mc:Ignorable="d" 
         d:DesignHeight="600" d:DesignWidth="800"
         Foreground="CornflowerBlue"
         Title="时间表编辑器">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 操作按钮区域 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <Button x:Name="btnAdd" Content="添加时间段" Click="btnAdd_Click" Width="120"/>
            <Button x:Name="btnEdit" Content="编辑时间段" Click="btnEdit_Click" Width="120"/>
            <Button x:Name="btnDelete" Content="删除时间段" Click="btnDelete_Click" Width="120"/>
            <Button x:Name="btnSave" Content="保存" Click="btnSave_Click" Width="80"/>
        </StackPanel>

        <!-- 表格区域 -->
        <DataGrid x:Name="dgTimeSlots" Grid.Row="1" AutoGenerateColumns="False" CanUserSortColumns="True" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="时间段名称" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="开始日期" Binding="{Binding StartDate}" Width="120"/>
                <DataGridTextColumn Header="开始时间" Binding="{Binding StartTime}" Width="120"/>
                <DataGridTextColumn Header="结束日期" Binding="{Binding EndDate}" Width="120"/>
                <DataGridTextColumn Header="结束时间" Binding="{Binding EndTime}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 状态信息 -->
        <TextBlock Grid.Row="2" x:Name="txtStatus" Margin="0,10,0,0" Foreground="Green"/>
    </Grid>
</ui:Page>
